<%- include('layout/header', { title: 'Dashboard', pageClass: 'page-dashboard' }) %>
<%- include('layout/nav') %>

<main class="main-content">
  <!-- Page Header -->
  <div class="page-header">
    <div class="page-title-row">
      <h1>Covered Calls Dashboard</h1>
      <span class="number text-muted">Current System Time: 2026-05-26</span>
    </div>
    <p class="page-subtitle">Your real-time options writing and premium harvest overview.</p>
  </div>

  <!-- Flash Messages -->
  <% if (flash.success) { %>
    <div class="badge badge--closed w-full m-b-4" style="padding: var(--space-3); border-radius: var(--radius-md);">
      <%= flash.success %>
    </div>
  <% } %>
  <% if (flash.error) { %>
    <div class="error-banner w-full">
      <%= flash.error %>
    </div>
  <% } %>

  <!-- Summary Bar -->
  <div class="grid-2x2-mobile">
    <!-- Stat Card: Total P&L -->
    <div class="stat-card <%= summary.totalPnL >= 0 ? 'stat-card--positive' : 'stat-card--negative' %>">
      <span class="stat-label">Total Realized P&L</span>
      <span class="stat-value number <%= summary.totalPnL >= 0 ? 'text-success' : 'text-danger' %>">
        <%= summary.totalPnL >= 0 ? '+' : '' %><%= summary.totalPnL.toLocaleString('en-US', { style: 'currency', currency: 'USD' }) %>
      </span>
    </div>

    <!-- Stat Card: Win Rate -->
    <div class="stat-card stat-card--accent">
      <span class="stat-label">Win Rate</span>
      <span class="stat-value number text-success">
        <%= summary.winRate.toFixed(2) %>%
      </span>
    </div>

    <!-- Stat Card: Active Positions -->
    <div class="stat-card stat-card--warning">
      <span class="stat-label">Open Positions</span>
      <span class="stat-value number">
        <%= summary.openPositions %> <span style="font-size: var(--text-sm); font-weight: 500; color: var(--color-text-secondary);">(<%= summary.openTrades %> calls sold)</span>
      </span>
    </div>

    <!-- Stat Card: 30D Rolling Premium -->
    <div class="stat-card stat-card--positive">
      <span class="stat-label">30-Day Premium</span>
      <span class="stat-value number text-success">
        <%= summary.monthlyIncome.toLocaleString('en-US', { style: 'currency', currency: 'USD' }) %>
      </span>
    </div>
  </div>

  <!-- Layout split: Charts & Positions -->
  <div class="grid-1-col grid-2-col-desktop">
    <!-- Monthly Income Chart -->
    <div class="chart-container">
      <div class="chart-header">
        <h3 class="chart-title">Income History (12 Months)</h3>
      </div>
      <canvas id="monthly-income-canvas"></canvas>
    </div>

    <!-- Open Positions -->
    <div class="card flex flex-col gap-4">
      <div class="card-header">
        <h3 class="card-title">Open Call Positions</h3>
        <a href="/positions" class="btn btn--secondary btn--sm">View All</a>
      </div>

      <% if (openPositions.length === 0) { %>
        <div class="empty-state" style="padding: var(--space-6);">
          <svg class="empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="8" y1="12" x2="16" y2="12"></line>
          </svg>
          <span class="empty-title">No Open Positions</span>
          <p class="empty-text">Click below to record your first covered call underlying purchase.</p>
          <a href="/positions/add" class="btn btn--primary btn--sm">Create Position</a>
        </div>
      <% } else { %>
        <!-- Mobile scroll strip -->
        <div class="scroll-strip flex lg:hidden">
          <% openPositions.forEach(p => { %>
            <div class="card scroll-strip-card flex flex-col gap-2">
              <div class="flex justify-between align-center">
                <span class="number" style="font-size: var(--text-lg); font-weight: 700;"><%= p.ticker %></span>
                <span class="badge badge--active">Active</span>
              </div>
              <div class="flex justify-between text-muted" style="font-size: var(--text-sm);">
                <span>Shares:</span>
                <span class="number" style="color: var(--color-text-primary);"><%= p.shares_owned %></span>
              </div>
              <div class="flex justify-between text-muted" style="font-size: var(--text-sm);">
                <span>Cost Basis:</span>
                <span class="number" style="color: var(--color-text-primary);">$<%= p.avg_cost_basis.toFixed(2) %></span>
              </div>
              <div class="flex justify-between text-muted" style="font-size: var(--text-sm);">
                <span>Premium Rec:</span>
                <span class="number text-success">$<%= p.total_premium.toFixed(2) %></span>
              </div>
              <div class="flex justify-between text-muted" style="font-size: var(--text-sm);">
                <span>Open Trades:</span>
                <span class="number" style="color: var(--color-text-primary);"><%= p.open_trades %></span>
              </div>
              <a href="/positions/<%= p.id %>" class="btn btn--secondary btn--sm w-full m-t-2">Detail Deep Dive</a>
            </div>
          <% }) %>
        </div>

        <!-- Desktop Grid View Table -->
        <div class="table-wrapper hidden lg:block" style="border: none;">
          <table class="data-table">
            <thead>
              <tr>
                <th>Ticker</th>
                <th>Shares</th>
                <th>Avg Cost Basis</th>
                <th>Premium Collected</th>
                <th>Open Contracts</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% openPositions.forEach(p => { %>
                <tr>
                  <td class="number" style="font-weight: 700; font-size: var(--text-base);"><%= p.ticker %></td>
                  <td class="number"><%= p.shares_owned %></td>
                  <td class="number">$<%= p.avg_cost_basis.toFixed(2) %></td>
                  <td class="number text-success">$<%= p.total_premium.toFixed(2) %></td>
                  <td class="number"><%= p.open_trades %></td>
                  <td>
                    <a href="/positions/<%= p.id %>" class="btn btn--secondary btn--sm">Detail</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Recent Activity Feed -->
  <div class="card flex flex-col gap-4">
    <div class="card-header">
      <h3 class="card-title">Recent Activity</h3>
    </div>

    <% if (recentActivity.length === 0) { %>
      <div class="empty-state" style="padding: var(--space-6);">
        <p class="empty-text">No trades or positions logged yet.</p>
      </div>
    <% } else { %>
      <div class="table-wrapper">
        <table class="data-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Ticker</th>
              <th>Strike</th>
              <th>Expiry</th>
              <th>Contracts</th>
              <th>Premium Received</th>
              <th>Status</th>
              <th>P&L</th>
            </tr>
          </thead>
          <tbody>
            <% recentActivity.forEach(a => { %>
              <tr>
                <td class="number"><%= a.opened_at %></td>
                <td class="number" style="font-weight: 600;"><%= a.ticker %></td>
                <td class="number">$<%= a.strike_price.toFixed(2) %></td>
                <td class="number"><%= a.expiration_date %></td>
                <td class="number"><%= a.contracts %></td>
                <td class="number text-success">$<%= a.premium_received.toFixed(2) %></td>
                <td>
                  <span class="badge badge--<%= a.status %>"><%= a.status %></span>
                </td>
                <td class="number <%= a.status === 'open' ? 'text-muted' : (a.profit_loss >= 0 ? 'text-success' : 'text-danger') %>">
                  <%= a.status === 'open' ? '--' : (a.profit_loss >= 0 ? '+' : '') + '$' + a.profit_loss.toFixed(2) %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- FAB for Mobile Quick Adding -->
  <a href="/positions/add" class="fab lg:hidden" title="Add Position">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="12" y1="5" x2="12" y2="19"></line>
      <line x1="5" y1="12" x2="19" y2="12"></line>
    </svg>
  </a>
</main>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Inject the monthly income chart data safely from EJS
    const monthlyIncomeData = <%- JSON.stringify(monthlyIncome) %>;
    if (window.Charts && window.Charts.initMonthlyIncomeChart) {
      window.Charts.initMonthlyIncomeChart('monthly-income-canvas', monthlyIncomeData);
    }
  });
</script>

<%- include('layout/footer') %>
