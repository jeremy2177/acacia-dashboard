<%- include('../layout/header', { title: 'Add Underlying Position', pageClass: 'page-positions-add' }) %>
<%- include('../layout/nav') %>

<main class="main-content">
  <!-- Page Header / Breadcrumbs -->
  <div class="page-header">
    <div style="font-size: var(--text-xs); color: var(--color-text-secondary); display: flex; gap: var(--space-2);">
      <a href="/positions" style="text-decoration: underline;">Positions</a>
      <span>&gt;</span>
      <span>Add Position</span>
    </div>
    <h1 class="m-t-2">Log New Underlying Position</h1>
    <p class="page-subtitle">Record your stock or ETF purchase details. Options contracts are mapped to these share holdings.</p>
  </div>

  <!-- Form container -->
  <div class="card" style="max-width: 600px; margin: 0 auto; width: 100%;">
    <div class="card-header">
      <h3 class="card-title">Stock / ETF Details</h3>
    </div>

    <!-- Error messages banner -->
    <% if (errors.length > 0) { %>
      <div class="error-banner">
        <strong>Error:</strong>
        <ul style="margin-left: var(--space-4); margin-top: var(--space-1);">
          <% errors.forEach(err => { %>
            <li><%= err %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <form action="/positions" method="POST" class="flex flex-col gap-4">
      <div class="form-row">
        <!-- Ticker -->
        <div class="form-group">
          <label for="ticker" class="form-label">Ticker Symbol</label>
          <input type="text" id="ticker" name="ticker" class="form-control" placeholder="e.g. AAPL" required value="<%= data.ticker || '' %>" style="text-transform: uppercase;">
          <span class="form-helper">Capital letters only (e.g. MSFT, SPY)</span>
        </div>

        <!-- Shares Owned -->
        <div class="form-group">
          <label for="shares_owned" class="form-label">Shares Owned</label>
          <input type="number" id="shares_owned" name="shares_owned" class="form-control" placeholder="100, 200, etc." required min="100" step="100" value="<%= data.shares_owned || '' %>">
          <span id="contract-prefill-helper" class="form-helper text-warning">Must be a multiple of 100 (1 standard contract)</span>
        </div>
      </div>

      <div class="form-row">
        <!-- Average Cost Basis -->
        <div class="form-group">
          <label for="avg_cost_basis" class="form-label">Average Cost Basis ($)</label>
          <input type="number" id="avg_cost_basis" name="avg_cost_basis" class="form-control" placeholder="e.g. 145.50" required min="0.01" step="0.01" value="<%= data.avg_cost_basis || '' %>">
          <span class="form-helper">Your average purchase price per share</span>
        </div>

        <!-- Opened Date -->
        <div class="form-group">
          <label for="opened_at" class="form-label">Purchase Date</label>
          <input type="date" id="opened_at" name="opened_at" class="form-control" required value="<%= data.opened_at || '' %>">
          <span class="form-helper">When you bought the underlying shares</span>
        </div>
      </div>

      <!-- Notes -->
      <div class="form-group">
        <label for="notes" class="form-label">Notes (Optional)</label>
        <textarea id="notes" name="notes" class="form-control" rows="3" placeholder="Enter notes or comments regarding this holding..."><%= data.notes || '' %></textarea>
      </div>

      <!-- Form Actions -->
      <div class="form-actions flex justify-end gap-3 m-t-4">
        <a href="/positions" class="btn btn--secondary">Cancel</a>
        <button type="submit" class="btn btn--primary">
          <span>Log & Proceed</span>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </div>
    </form>
  </div>
</main>

<%- include('../layout/footer') %>
